# Nginx configuration for crcdb.org -- the rcdb WSGI application.
#
# rcdb.web is a server-rendered Flask app (no SPA). nginx reverse-proxies
# every request to the Gunicorn process managed by the `crcdb` systemd unit,
# listening on 127.0.0.1:5455. Flask itself serves the app's /static assets.
#
# This listens on plain HTTP :80. Terminate TLS either at nginx (see
# nginx-crcdb-https) or at an upstream proxy/load balancer.

server {
    listen 80;
    listen [::]:80;

    # Match by domain name only (do not answer to the bare IP).
    server_name crcdb.org www.crcdb.org;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Logging
    access_log /var/log/nginx/crcdb.access.log;
    error_log  /var/log/nginx/crcdb.error.log;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml;

    # Allow reasonably large request bodies (search forms etc.)
    client_max_body_size 20m;

    # Reverse proxy everything to the rcdb Gunicorn app
    location / {
        proxy_pass http://127.0.0.1:5455;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Timeouts for occasional slow DB queries
        proxy_connect_timeout 60s;
        proxy_send_timeout    120s;
        proxy_read_timeout    120s;

        # Buffering for larger rendered pages
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 32k;
        proxy_busy_buffers_size 64k;
    }

    # Optional fast path: serve rcdb's static assets straight from the
    # installed package instead of through Flask. Enable only after verifying
    # the venv site-packages path below matches your install.
    # location /static/ {
    #     alias /opt/crcdb/venv/lib/python3.12/site-packages/rcdb/web/static/;
    #     expires 7d;
    #     access_log off;
    # }

    # Deny access to hidden files (except .well-known for ACME challenges)
    location ~ /\.(?!well-known) {
        deny all;
    }
}
