# Nginx configuration for crcdb.org -- STEP 1: static test page only.
#
# Serves a static placeholder on plain HTTP :80 to confirm DNS and nginx
# routing before the WSGI app is introduced. Once the WSGI/rcdb part is
# ready, replace this file with `nginx-crcdb`.

server {
    listen 80;
    listen [::]:80;

    # Match by domain name only (do not answer to the bare IP).
    server_name crcdb.org www.crcdb.org;

    # Document root for the static test page
    root /var/www/crcdb;
    index index.html;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Logging
    access_log /var/log/nginx/crcdb.access.log;
    error_log  /var/log/nginx/crcdb.error.log;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml;

    # Serve the static test page
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Deny access to hidden files (except .well-known for ACME challenges)
    location ~ /\.(?!well-known) {
        deny all;
    }
}
